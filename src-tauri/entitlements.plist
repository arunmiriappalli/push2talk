<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Tauri's bundler enables Hardened Runtime by default even for ad-hoc
         signing. Under Hardened Runtime, kTCCServiceMicrophone additionally
         requires this entitlement — without it, macOS blocks CoreAudio input
         entirely (no permission prompt, no entry in the Microphone privacy
         pane, no error) even though Info.plist declares
         NSMicrophoneUsageDescription. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
